# Copy these names when adding GitHub Secrets. Do NOT put real values here.
# In GitHub: repo → Settings → Secrets and variables → Actions → New repository secret

RESY_API_KEY=your_api_key_from_Authorization_header
RESY_AUTH_TOKEN=your_full_x_resy_auth_token
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16_char_gmail_app_password
NOTIFY_EMAIL=where_to_send_alert@gmail.com
